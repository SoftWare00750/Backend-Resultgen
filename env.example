# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Postgres connection (either DATABASE_URL or the discrete fields below)
DATABASE_URL=postgres://rgs_user:rgs_password@localhost:5432/rgs_db

PGHOST=localhost
PGPORT=5432
PGDATABASE=rgs_db
PGUSER=rgs_user
PGPASSWORD=rgs_password

# CORS - the URL of the Next.js frontend
CLIENT_ORIGIN=http://localhost:3000

# First admin auto-seeded on first migrate/seed run
SEED_ADMIN_EMAIL=admin@school.edu.ng
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=System Administrator
